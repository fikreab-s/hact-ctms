# =============================================================================
# HACT CTMS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in production values.
# DO NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-random-64-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# -----------------------------------------------------------------------------
# PostgreSQL — HACT Custom Database
# -----------------------------------------------------------------------------
POSTGRES_DB=hact_ctms_db
POSTGRES_USER=hact_admin
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# PostgreSQL — Keycloak Database
# -----------------------------------------------------------------------------
KC_DB_NAME=keycloak_db
KC_DB_USER=keycloak_admin
KC_DB_PASSWORD=change-me-keycloak-db-password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password
KEYCLOAK_REALM=hact
KEYCLOAK_SERVER_URL=http://keycloak:8080/auth
KEYCLOAK_CLIENT_ID=hact-ctms
KEYCLOAK_CLIENT_SECRET=change-me-keycloak-client-secret

# -----------------------------------------------------------------------------
# OIDC Settings (mozilla-django-oidc)
# -----------------------------------------------------------------------------
OIDC_RP_CLIENT_ID=hact-ctms
OIDC_RP_CLIENT_SECRET=change-me-keycloak-client-secret
OIDC_OP_AUTHORIZATION_ENDPOINT=http://localhost/auth/realms/hact/protocol/openid-connect/auth
OIDC_OP_TOKEN_ENDPOINT=http://keycloak:8080/auth/realms/hact/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=http://keycloak:8080/auth/realms/hact/protocol/openid-connect/userinfo
OIDC_OP_JWKS_ENDPOINT=http://keycloak:8080/auth/realms/hact/protocol/openid-connect/certs

# -----------------------------------------------------------------------------
# External Services (future phases)
# -----------------------------------------------------------------------------
# OPENCLINICA_URL=http://openclinica:8080/OpenClinica
# OPENCLINICA_API_TOKEN=
