# SENAITE -> CTMS results-published notifier config.
# Copy to /etc/senaite-webhook-notifier.env on the SENAITE host and fill in.
# NOTE: contains a secret — chmod 600 and keep out of version control.

# SENAITE JSON API base (the same box can use its internal address to avoid the
# public round-trip; the public URL below is known-good).
SENAITE_API_URL=https://ctms.hacts.org/senaite/@@API/senaite/v1
SENAITE_API_USER=admin
SENAITE_API_PASSWORD=change-me

# CTMS inbound webhook + shared secret (must equal CTMS's SENAITE_WEBHOOK_SECRET).
CTMS_WEBHOOK_URL=https://ctms.hacts.org/api/v1/integrations/senaite/webhook/results-published/
SENAITE_WEBHOOK_SECRET=change-me-to-match-ctms

# Optional: only notify samples under this SENAITE Client (leave blank for all).
CLIENT_TITLE=HACT Clinical Trials

# Optional tuning.
STATE_FILE=/var/lib/senaite-webhook-notifier/state.json
LIMIT=200
# Set to 0 only if SENAITE uses a self-signed/local TLS cert.
VERIFY_TLS=1
